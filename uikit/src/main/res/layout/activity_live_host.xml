<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Full-screen camera preview -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Co-streamer strip (top-right, multiple tiles stacked vertically, scrollable) -->
    <ScrollView
        android:id="@+id/coStreamScrollView"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="12dp"
        android:elevation="4dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/coStreamStrip"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Top gradient scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="top"
        android:background="@drawable/live_top_gradient" />

    <!-- Bottom gradient scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/live_bottom_gradient" />

    <!-- ══ TOP BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- Host info: avatar + name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/hostAvatarImageView"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/live_avatar_placeholder"
                android:scaleType="centerCrop"
                android:clipToOutline="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/hostNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:maxWidth="120dp"
                    android:ellipsize="end" />

                <!-- LIVE badge -->
                <TextView
                    android:id="@+id/liveIndicatorTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/live_badge_bg"
                    android:text="LIVE"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Viewer count -->
            <TextView
                android:id="@+id/viewerCountTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="0"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_live_viewer"
                android:drawablePadding="3dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Right action buttons: share, float, close -->
        <ImageButton
            android:id="@+id/shareButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/round_bg_30_half_transparent"
            android:src="@drawable/ic_share_white"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/live_share" />

        <ImageButton
            android:id="@+id/floatButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/round_bg_30_half_transparent"
            android:src="@drawable/ic_pip"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/live_float" />

        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/round_bg_30_half_transparent"
            android:src="@drawable/ic_close_white"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/live_close" />

    </LinearLayout>

    <!-- ══ BOTTOM BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/messageFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="8dp" />

        <!-- Controls row: say-something + icon buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- "说点什么..." input pill -->
            <TextView
                android:id="@+id/sayingSomethingView"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/live_input_bg"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/live_say_something"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <!-- Camera switch -->
            <ImageButton
                android:id="@+id/cameraButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/round_bg_30_half_transparent"
                android:src="@drawable/ic_live_flip_camera"
                android:padding="10dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@string/live_streaming_switch_camera" />

            <!-- Record system audio -->
            <ImageButton
                android:id="@+id/recordAudioButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/round_bg_30_half_transparent"
                android:src="@drawable/ic_live_mic"
                android:padding="10dp"
                android:layout_marginStart="10dp"
                android:contentDescription="录制系统音频" />

            <!-- Co-stream management: icon + badge overlay -->
            <FrameLayout
                android:id="@+id/coStreamButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/coStreamIconButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/round_bg_30_half_transparent"
                    android:src="@drawable/ic_live_co_manage"
                    android:padding="10dp"
                    android:contentDescription="@string/live_co_stream_manage" />

                <!-- Red badge for pending requests -->
                <TextView
                    android:id="@+id/coStreamBadgeView"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="2dp"
                    android:background="@drawable/live_badge_dot"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="72dp"
            android:text="@string/live_streaming_starting"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </FrameLayout>

</FrameLayout>
