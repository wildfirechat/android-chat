<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#DDDDDD"
        android:layout_margin="4dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/live_co_stream_manage"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Section: Active co-streamers -->
    <TextView
        android:id="@+id/activeSection"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="@string/live_co_stream_active_section"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#F7F7F7" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/activeCoStreamersRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <!-- Section: Pending requests -->
    <TextView
        android:id="@+id/requestingSection"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="@string/live_co_stream_requesting_section"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#F7F7F7" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/requestingRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <!-- Section: Invitable viewers -->
    <TextView
        android:id="@+id/invitableSection"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="@string/live_co_stream_invitable_section"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#F7F7F7" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/invitableRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

</LinearLayout>

