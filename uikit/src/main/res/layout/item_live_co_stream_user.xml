<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="16dp">

    <!-- Avatar with online indicator -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <ImageView
            android:id="@+id/userAvatarImageView"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/live_avatar_placeholder"
            android:scaleType="centerCrop"
            android:clipToOutline="true" />

    </FrameLayout>

    <!-- Name + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/userNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/userStatusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Secondary action (e.g., 拒绝) -->
    <TextView
        android:id="@+id/secondaryActionButton"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:background="@drawable/live_btn_outline"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginEnd="8dp"
        android:visibility="gone" />

    <!-- Primary action (e.g., 同意 / 结束) -->
    <TextView
        android:id="@+id/primaryActionButton"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:background="@drawable/live_btn_primary"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:textSize="13sp"
        android:textColor="@android:color/white" />

</LinearLayout>

