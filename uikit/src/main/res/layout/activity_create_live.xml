<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray5"
    android:orientation="vertical">

    <include layout="@layout/toolbar" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="20dp"
        app:boxBackgroundMode="none"
        app:hintEnabled="true">

        <cn.wildfire.chat.kit.widget.FixedTextInputEditText
            android:id="@+id/liveTitleEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="直播主题"
            android:paddingTop="6dp"
            android:textSize="16sp"
            android:maxLength="20"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <View
        style="@style/Line"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="20dp"
        app:boxBackgroundMode="none"
        app:hintEnabled="true">

        <cn.wildfire.chat.kit.widget.FixedTextInputEditText
            android:id="@+id/liveDescEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="直播描述"
            android:paddingTop="6dp"
            android:textSize="16sp"
            android:maxLength="100"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@color/white"
        android:orientation="vertical">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/audienceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:padding="20dp"
            android:visibility="visible"
            android:text="是否禁止连麦" />

        <View
            style="@style/Line"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/audioOnlySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:checked="false"
            android:padding="20dp"
            android:text="语音直播" />

        <View
            style="@style/Line"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/recordSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:padding="20dp"
            android:text="进行录制" />

        <View
            style="@style/Line"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/groupLiveSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:padding="20dp"
            android:text="是否禁止非群成员观看" />

    </LinearLayout>

    <Button
        android:id="@+id/createLiveBtn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="10dp"
        android:text="开始直播"
        android:textColor="@color/av_conference_button_text_color_selector"
        android:textSize="16sp" />

</LinearLayout>